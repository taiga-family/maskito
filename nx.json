{
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "analytics": false,
    "defaultBase": "origin/main",
    "defaultProject": "demo",
    "generators": {
        "@nx/angular:application": {
            "linter": "none",
            "style": "less",
            "unitTestRunner": "jest"
        },
        "@nx/angular:component": {
            "style": "less"
        },
        "@nx/angular:library": {
            "buildable": true,
            "compilationMode": "partial",
            "linter": "none",
            "publishable": true,
            "skipModule": true,
            "standaloneConfig": true,
            "strict": true,
            "unitTestRunner": "jest"
        },
        "@nx/js:library": {
            "buildable": true,
            "config": "project",
            "linter": "none",
            "publishable": true,
            "strict": true,
            "unitTestRunner": "jest"
        },
        "@nx/react-native:library": {
            "linter": "eslint",
            "publishable": true,
            "strict": true,
            "unitTestRunner": "jest"
        },
        "@nx/react:library": {
            "bundler": "rollup",
            "linter": "eslint",
            "publishable": true,
            "strict": true,
            "style": "none",
            "unitTestRunner": "jest"
        }
    },
    "namedInputs": {
        "default": ["{projectRoot}/**/*", "sharedGlobals"],
        "production": [
            "default",
            "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
            "!{projectRoot}/tsconfig.spec.json",
            "!{projectRoot}/jest.config.[jt]s",
            "!{projectRoot}/src/test-setup.[jt]s",
            "!{projectRoot}/**/*.cy.[jt]s?(x)",
            "!{projectRoot}/cypress.config.[jt]s"
        ],
        "sharedGlobals": [
            "{workspaceRoot}/angular.json",
            "{workspaceRoot}/nx.json",
            "{workspaceRoot}/karma.*.js",
            "{workspaceRoot}/tsconfig.*.json",
            "{workspaceRoot}/tsconfig.json",
            "{workspaceRoot}/babel.config.json",
            "{workspaceRoot}/rollup.config.ts"
        ]
    },
    "parallel": 3,
    "targetDefaults": {
        "@nx/jest:jest": {
            "cache": true,
            "configurations": {
                "ci": {
                    "ci": true,
                    "codeCoverage": true
                }
            },
            "inputs": [
                "default",
                "^production",
                "{workspaceRoot}/jest.preset.js"
            ],
            "options": {
                "passWithNoTests": true
            }
        },
        "@nx/rollup:rollup": {
            "cache": true,
            "dependsOn": ["^build"],
            "inputs": [
                "production",
                "^production",
                {
                    "fields": [
                        "extends",
                        "files",
                        "include"
                    ],
                    "json": "{workspaceRoot}/tsconfig.json"
                }
            ]
        },
        "build": {
            "cache": true,
            "inputs": ["production", "^production"]
        },
        "component-test": {
            "cache": true,
            "inputs": ["default", "^production"]
        },
        "ct-react": {
            "cache": true,
            "inputs": ["default", "^production"]
        },
        "lint": {
            "cache": true
        }
    },
    "tui": {
        "enabled": false
    },
    "useInferencePlugins": false,
    "workspaceLayout": {
        "appsDir": "projects",
        "libsDir": "projects"
    }
}
