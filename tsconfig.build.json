{
    "extends": "./tsconfig.json",
    "include": ["**/src/**/*.ts", "**/src/**/*.tsx", "**/src/**/*.d.ts"],
    "exclude": ["**/*.spec.ts", "**/*.spec.tsx"],
    "compilerOptions": {
        "declaration": true,
        "declarationMap": true,
        "types": [],
        "inlineSources": true,
        "incremental": false
    },
    "angularCompilerOptions": {
        "compilationMode": "partial"
    }
}
