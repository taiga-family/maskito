{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "declaration": true,
        "declarationMap": true,
        "incremental": false,
        "inlineSources": true,
        "types": []
    },
    "angularCompilerOptions": {
        "compilationMode": "partial"
    },
    "include": [
        "**/src/**/*.ts",
        "**/src/**/*.tsx",
        "**/src/**/*.d.ts"
    ],
    "exclude": ["**/*.spec.ts", "**/*.spec.tsx"]
}
